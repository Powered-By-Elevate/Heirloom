# Public Supabase config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Server-side admin operations (account deletion, member email lookups).
# Find at Supabase Dashboard → Project Settings → API → service_role (secret).
# NEVER commit a real value here or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side AI for recipe extraction from images.
# Free tier: 15 req/min, 1500/day on gemini-2.0-flash.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Absolute site URL for invite links and sitemap entries.
# In dev this can stay unset (defaults to http://localhost:3000).
# In production, set this to your deployed URL (e.g. https://heirloom-orcin.vercel.app).
NEXT_PUBLIC_SITE_URL=
